#!/usr/bin/env bash
set -euo pipefail

# ===== Config =====
DRY_RUN=0
ROOT="."

for arg in "$@"; do
  case "$arg" in
    --dry-run)
      DRY_RUN=1
      ;;
    *)
      ROOT="$arg"
      ;;
  esac
done

# Exact removable standalone bracket values
REMOVE_FULL_BRACKETS=(
  "12 Remix"
  "2003 Radio Cut"
  "Album Mix"
  "Album Version"
  "Album Version Edited"
  "Bonus"
  "Bonus Track"
  "Dance Edit"
  "Edit Mix"
  "Euto Cut"
  "Extended Alternative Mix 2K13
  "Extended Edit"
  "Extended Mix"
  "Extended Mix 2K13""
  "Less Mix"
  "Live"
  "Main"
  "Main Mix"
  "Maxi Cut"
  "Maxi Version"
  "Mix"
  "Original"
  "Original Album Mix"
  "Original Bonus Track"
  "Original Club Mix"
  "Original Extended"
  "Original Mix"
  "Original Mix Edit"
  "Original Mix Short Edit"
  "Original Radio Cut"
  "Original Radio Cut 2k5"
  "Original Remix"
  "Radio Cut"
  "Radio Edit"
  "Radio Edit Long"
  "Radio Edit Mix"
  "Radio Edit Short"
  "Radio Mix"
  "Radio Version"
  "Remix Maxi"
  "Short Edit"
  "Single Cut"
  "Single Edit"
  "Single Mix 2K13"
  "Single Version"
  "Video Cut"
  "Video Edit"
)

# Remove unwanted Mix/Remix qualifiers
NORMALIZE_SUFFIXES=(
  "Extended Mix|Mix"
  "Mix Cut|Mix"
  "Radio Cut|Mix"
  "Remix Cut|Remix"
  "Remix Edit|Remix"
  "Rmx|Remix"
  "Short Mix|Mix"
)

# ==================

trim() {
  sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//; s/[[:space:]]{2,}/ /g'
}

clean_artist() {
  local s="$1"

  # Clean up artist tag
  # 1. Removes feat/featuring/ft
  # 2. Changes "vs" to "vs."
  # 3. Prevents repeated "vs." normalization (avoids adding extra dots on reruns)
  # 4. Normalizes whitespace and trims leading/trailing spaces
  printf '%s' "$s" | perl -CS -pe '
    s/\s+(feat\.?|featuring|ft\.?)\s+.*$//i;
    s/\bvs\b(?!\.)/vs./ig;
    s/\s{2,}/ /g;
    s/^\s+|\s+$//g;
  '
}

clean_title() {
  local s="$1"

  # 1. Remove standalone braackets from song title
  # Removes featureds
  s="$(printf '%s' "$s" | perl -CS -pe '
    s/\s*\((feat\.?|ft\.?)\s+[^()]*\)//ig;
  ')"

  # Removes "(Original Mix)" and other REMOVE_FULL_BRACKETS strings
  for item in "${REMOVE_FULL_BRACKETS[@]}"; do
    s="$(printf '%s' "$s" | perl -CS -pe "s/\\s*\\(${item// /\\ }\\)//ig;")"
  done

  # 2. Pattern-based transforms
  # Converts "(Artist Radio Edit/Mix)" => "(Artist Remix)"
  s="$(printf '%s' "$s" | perl -CS -pe '
    s/\(([^()]+?)\s+Radio\s+(Edit|Mix)\)/($1 Remix)/ig;
  ')"

  # 3. Simple suffix normalizations
  # Replaces "<value> Mix)" => "Mix)" and other NORMALIZE_SUFFIXES replacements
  for rule in "${NORMALIZE_SUFFIXES[@]}"; do
    from="${rule%%|*}"
    to="${rule##*|}"

    s="$(printf '%s' "$s" | perl -CS -pe \
      "s/${from// /\\\\ }\\)/${to})/ig;")"
  done

  printf '%s' "$s" | perl -CS -pe '
    s/\s{2,}/ /g;
    s/\s+\)/)/g;
    s/\(\s+/\(/g;
    s/^\s+|\s+$//g;
  '
}

process_file() {
  local file="$1"
  local artist title new_artist new_title tmp

  artist="$(ffprobe -v error -show_entries format_tags=artist -of default=nw=1:nk=1 "$file" || true)"
  title="$(ffprobe -v error -show_entries format_tags=title  -of default=nw=1:nk=1 "$file" || true)"

  new_artist="$(clean_artist "$artist")"
  new_title="$(clean_title "$title")"

  if [[ "$artist" == "$new_artist" && "$title" == "$new_title" ]]; then
    return
  fi

  echo "Updating: $file"

  if [[ "$artist" != "$new_artist" ]]; then
    echo "  Artist: [$artist] -> [$new_artist]"
  fi

  if [[ "$title" != "$new_title" ]]; then
    echo "  Title : [$title] -> [$new_title]"
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    return
  fi

  tmp="${file}.tmp.mp3"

  ffmpeg -v error -y \
    -i "$file" \
    -map 0 \
    -c copy \
    -metadata artist="$new_artist" \
    -metadata title="$new_title" \
    "$tmp"

  mv -f "$tmp" "$file"
}

export -f clean_artist clean_title process_file

find "$ROOT" -type f \( -iname '*.mp3' \) -print0 |
while IFS= read -r -d '' file; do
  process_file "$file"
done